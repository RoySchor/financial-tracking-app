# Plaid credentials (from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here

# Plaid access tokens — one per institution (NEVER lose these, they burn an Item slot)
# Run the Plaid Link flow to generate these
PLAID_ACCESS_TOKEN_CHASE=
PLAID_ACCESS_TOKEN_CAPITALONE=

# Google Sheets (service account JSON path)
GOOGLE_SHEETS_CREDENTIALS=path/to/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Database path (defaults to ./data/finance.db)
# DB_PATH=./data/finance.db
